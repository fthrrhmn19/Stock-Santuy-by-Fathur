MARKET_DATA_PROVIDER=twelvedata
TWELVE_DATA_API_KEY=masukkan_api_key
ENABLE_YAHOO_FALLBACK=true
IDX_API_BASE_URL=
IDX_API_KEY=
IDX_CLIENT_ID=
IDX_CLIENT_SECRET=

# Opsional. Jika diisi, pengunjung harus login.
# Buat hash dengan:
# node -e "const crypto=require('crypto');const p='password_anda';const s=crypto.randomBytes(16).toString('hex');const i=210000;console.log('pbkdf2_sha256$'+i+'$'+s+'$'+crypto.pbkdf2Sync(p,s,i,32,'sha256').toString('hex'))"
ACCESS_PASSWORD_HASH=
SESSION_SECRET=ganti_dengan_string_acak_panjang
ALLOWED_ORIGIN=https://stock-santuy.netlify.app

CACHE_TTL_QUOTE=60
CACHE_TTL_INTRADAY=60
CACHE_TTL_DAILY=3600
LIVE_REFRESH_MS=60000

# Email alert otomatis via Resend.
# Jadwal Cloudflare:
# - signal-morning 00:00 WIB Senin-Jumat
# - signal-midday 12:00 WIB Senin-Jumat
# - signal-afternoon 15:40 WIB Senin-Jumat
# - signal-watch tiap 5 menit sekitar jam market untuk harmonic/bagger/swing entry
RESEND_API_KEY=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
ALERT_MIN_SCORE=78
ALERT_MANUAL_SECRET=
HARMONIC_ALERT_LOOKBACK=20
HARMONIC_ALERT_RECENT_LOOKBACK=1
WATCH_HARMONIC_COOLDOWN_HOURS=4
# Opsional untuk libur khusus BEI di luar kalender nasional/cuti bersama.
# Format: YYYY-MM-DD:Nama Libur,YYYY-MM-DD:Nama Libur
IDX_HOLIDAYS=
SITE_URL=https://stock-santuy.netlify.app
